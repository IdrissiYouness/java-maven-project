pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Compiling the Java application...'
                sh 'mvn clean compile'
            }
        }
        
        stage('Test') {
            steps {
                echo 'Running unit tests...'
                sh 'mvn test'
            }
        }
        
        stage('Package') {
            steps {
                echo 'Packaging into a JAR file...'
                sh 'mvn package -DskipTests'
            }
        }
        
        // TODO: Uncomment this stage when you reach Page 11 of the PDF
        /*
